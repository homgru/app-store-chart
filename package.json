{
  "name": "app-store-chart",
  "version": "1.0.0",
  "description": "앱스토어 순위 대시보드",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -n server,client,electron -c blue,green,yellow \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:electron\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "cd client && npx vite --port 5173",
    "dev:electron": "wait-on http://localhost:5173 http://localhost:3001 && npx cross-env NODE_ENV=development electron .",
    "build:electron": "esbuild electron/main.ts --bundle --platform=node --packages=external --external:electron --outfile=dist-electron/main.js",
    "build:client": "cd client && npx vite build",
    "build": "npm run build:electron && npm run build:client",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "google-play-scraper": "^9.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.0",
    "esbuild": "^0.25.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.appstorex.chart",
    "productName": "앱스토어 순위",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**",
      "client/dist/**",
      "node_modules/**"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
